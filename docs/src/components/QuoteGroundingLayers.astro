---
interface Layer {
  name: string;
  purpose: string;
  optional?: boolean;
}

interface Props {
  layers?: Layer[];
}

const isThai = Astro.url.pathname.includes("/th/");

const englishLayers: Layer[] = [
  { name: "cited_id resolution", purpose: "The source document referenced must exist in the evidence bundle." },
  { name: "Minimum length (≥ 25 chars)", purpose: "Rejects trivially generic quotes that could match by chance." },
  { name: "NFC normalization", purpose: "Unicode-normalize quote and source to NFC before text comparison." },
  { name: "Contiguous substring match", purpose: "The quote must appear verbatim within the cited source document." },
  { name: "Within-doc uniqueness", purpose: "The quote must occur exactly once in the cited document. No ambiguity." },
  { name: "Numeric-tuple agreement", purpose: "All numbers in the quote must match the structured evidence values." },
  {
    name: "Medical-NLI entailment",
    purpose:
      "Semantic check: does the quote actually support the LLM's clinical claim? Opt-in per PRD §9. The verifier runs this layer only when the caller passes a non-null nli_gate; default call sites do not.",
    optional: true,
  },
];

const thaiLayers: Layer[] = [
  { name: "cited_id resolution", purpose: "source document ที่ถูกอ้างต้องมีอยู่จริงใน evidence bundle" },
  { name: "Minimum length (≥ 25 chars)", purpose: "ตัด quote ที่สั้นหรือ generic เกินไปจน match ได้โดยบังเอิญ" },
  { name: "NFC normalization", purpose: "ปรับ quote และ source เป็น Unicode NFC ก่อนเทียบข้อความ" },
  { name: "Contiguous substring match", purpose: "quote ต้องปรากฏแบบ verbatim ภายใน source document ที่อ้าง" },
  { name: "Within-doc uniqueness", purpose: "quote ต้องพบใน document นั้นเพียงครั้งเดียว เพื่อลด ambiguity" },
  { name: "Numeric-tuple agreement", purpose: "ตัวเลขทั้งหมดใน quote ต้องตรงกับ structured evidence values" },
  {
    name: "Medical-NLI entailment",
    purpose:
      "ตรวจเชิง semantic ว่า quote สนับสนุน clinical claim ของ LLM จริงหรือไม่ เป็น opt-in ตาม PRD §9 และจะรันเมื่อ caller ส่ง nli_gate ที่ไม่ใช่ null เท่านั้น",
    optional: true,
  },
];

const defaultLayers = isThai ? thaiLayers : englishLayers;
const { layers = defaultLayers } = Astro.props;
---

<section class="grounding-layers" aria-label={isThai ? "Quote-grounding stack: 6 ชั้นบังคับและ NLI gate แบบ optional" : "Quote-grounding stack: 6 mandatory layers plus an optional NLI gate"}>
  <p class="grounding-layers__intro">
    {isThai ? (
      <>
        Quote grounding เป็นระบบ <strong>fail-closed และทำงานเป็นชั้น</strong>
        โดยก่อนเข้าชั้นแรก ระบบจะปฏิเสธ quote ว่างทันที จากนั้น 6 ชั้นหลักต้องรันทุกครั้ง
        หากชั้นใดไม่ผ่าน จะตั้ง
        <code>final_classification = NEEDS_REVIEW</code> พร้อม
        <code>review_reason = "hallucination_suspect"</code> ไม่ใช่
        <code>APPROPRIATE</code>/<code>INAPPROPRIATE</code> และห้าม mock หรือ
        short-circuit ชั้นเหล่านี้ใน test ส่วนชั้นที่ 7 (medical-NLI) เป็น opt-in
      </>
    ) : (
      <>
        Quote grounding is <strong>fail-closed and layered</strong>. Before layer 1, the
        verifier rejects empty quotes immediately. The six core layers always run; a
        failure on any of them sets
        <code>final_classification = NEEDS_REVIEW</code> with
        <code>review_reason = "hallucination_suspect"</code>, never an
        <code>APPROPRIATE</code>/<code>INAPPROPRIATE</code> result row. None of those six
        layers may be mocked or short-circuited in tests. The seventh layer (medical-NLI)
        is opt-in.
      </>
    )}
  </p>
  <ol class="grounding-layers__list" role="list">
    {layers.map((layer, idx) => (
      <li class:list={["grounding-layer", { "grounding-layer--optional": layer.optional }]}>
        <span class="grounding-layer__index" aria-hidden="true">
          {String(idx + 1).padStart(2, "0")}
        </span>
        <div class="grounding-layer__body">
          <div class="grounding-layer__head">
            <p class="grounding-layer__name">{layer.name}</p>
            {layer.optional && <span class="ba-pill ba-pill--warn">{isThai ? "เปิดใช้เมื่อกำหนด" : "opt-in"}</span>}
          </div>
          <p class="grounding-layer__purpose">{layer.purpose}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .grounding-layers {
    margin: 1.25rem 0;
  }
  .grounding-layers__intro {
    margin: 0 0 0.875rem;
    max-width: 70ch;
  }
  .grounding-layers__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .grounding-layer {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.875rem;
    padding: 0.75rem 0.875rem 0.875rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    transition: border-color var(--ba-duration-fast) var(--ba-ease-out);
  }
  .grounding-layer:hover {
    border-color: var(--sl-color-gray-4);
  }
  .grounding-layer--optional {
    border-style: dashed;
    background: transparent;
  }
  .grounding-layer__index {
    font-family: var(--ba-font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    line-height: 1.4;
  }
  .grounding-layer__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .grounding-layer__head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .grounding-layer__name {
    margin: 0;
    font-weight: 600;
    color: var(--sl-color-white);
  }
  .grounding-layer__purpose {
    margin: 0;
    color: var(--sl-color-gray-2);
    line-height: 1.55;
  }
  @media (prefers-reduced-motion: reduce) {
    .grounding-layer {
      transition: none;
    }
  }
</style>
