---
interface Stage {
  slug: string;
  label: string;
  module: string;
}

interface StageGroup {
  legLabel: string;
  legSubtitle: string;
  stages: Stage[];
}

interface Props {
  highlightStage?: string;
}

const groups: StageGroup[] = [
  {
    legLabel: "Ingest leg",
    legSubtitle: "Phase 1 — runs today via bba audit",
    stages: [
      { slug: "ingest", label: "Ingest", module: "bba.ingest" },
      { slug: "audit_orders", label: "Audit orders", module: "bba.audit_orders" },
      { slug: "hb_lookup", label: "Hb lookup", module: "bba.hb_lookup" },
      { slug: "vitals_extractor", label: "Vitals", module: "bba.vitals_extractor" },
      { slug: "cohort_detector", label: "Cohort", module: "bba.cohort_detector" },
    ],
  },
  {
    legLabel: "Analysis leg",
    legSubtitle: "Phase 1.5 — wired by the deployer",
    stages: [
      { slug: "deterministic_classifier", label: "Deterministic classify", module: "bba.deterministic_classifier" },
      { slug: "evidence_bundle_builder", label: "Evidence bundle", module: "bba.evidence_bundle_builder" },
      { slug: "deid_redactor", label: "De-identify", module: "bba.deid_redactor" },
      { slug: "prompt_builder", label: "Prompt build", module: "bba.prompt_builder" },
      { slug: "llm_client", label: "LLM batch", module: "bba.llm_client" },
      { slug: "quote_grounder", label: "Quote ground", module: "bba.quote_grounder" },
      { slug: "audit_store", label: "Audit store", module: "bba.audit_store" },
    ],
  },
];

const { highlightStage } = Astro.props;

let globalIndex = 0;
---

<figure class="pipeline ba-reveal" aria-label="blood_audit pipeline — 12 stages across 2 legs">
  {groups.map((group, gIdx) => (
    <section class="pipeline__leg" data-leg={gIdx === 0 ? "ingest" : "analysis"}>
      <header class="pipeline__leg-header">
        <p class="pipeline__leg-label">{group.legLabel}</p>
        <p class="pipeline__leg-subtitle">{group.legSubtitle}</p>
      </header>
      <ol class="pipeline__list" role="list" start={globalIndex + 1}>
        {group.stages.map((s) => {
          globalIndex += 1;
          const isActive = s.slug === highlightStage;
          return (
            <li
              class:list={["pipeline__stage", { "pipeline__stage--active": isActive }]}
              data-slug={s.slug}
              aria-current={isActive ? "step" : undefined}
            >
              <span class="pipeline__index" aria-hidden="true">{String(globalIndex).padStart(2, "0")}</span>
              <span class="pipeline__label">{s.label}</span>
              <code class="pipeline__module">{s.module}</code>
            </li>
          );
        })}
      </ol>
    </section>
  ))}
  <figcaption class="pipeline__caption">
    Twelve happy-path stages of <code>bba audit</code>. Each stage is an importable
    subpackage under <code>src/bba/</code>. Run-level idempotency is enforced at
    <code>audit_store</code>. The ingest leg runs today; the analysis leg is wired
    in Phase 1.5.
  </figcaption>
</figure>

<style>
  .pipeline {
    margin: 1.5rem 0 2rem;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
  .pipeline__leg {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.625rem;
    padding: 0.875rem 1rem 1rem;
    background: var(--sl-color-bg-nav);
  }
  .pipeline__leg[data-leg="analysis"] {
    border-style: dashed;
  }
  .pipeline__leg-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .pipeline__leg-label {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-accent);
  }
  .pipeline__leg-subtitle {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
  }
  .pipeline__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pipeline__stage {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
    transition: border-color var(--ba-duration-fast) var(--ba-ease-out),
                background-color var(--ba-duration-fast) var(--ba-ease-out);
  }
  .pipeline__stage:hover {
    border-color: var(--sl-color-accent);
  }
  .pipeline__stage--active {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }
  .pipeline__index {
    grid-row: 1 / span 2;
    align-self: center;
    font-family: var(--ba-font-mono);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    line-height: 1;
    letter-spacing: 0;
  }
  .pipeline__label {
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.3;
  }
  .pipeline__module {
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }
  .pipeline__caption {
    margin: 0;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    line-height: 1.55;
    max-width: 65ch;
  }
  @media (prefers-reduced-motion: reduce) {
    .pipeline__stage {
      transition: none;
    }
  }
</style>
