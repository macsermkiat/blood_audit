---
interface Tier {
  label: string;
  range: string;
  ruleOutput: "APPROPRIATE" | "NEEDS_REVIEW" | "POTENTIALLY_INAPPROPRIATE";
  routes: "auto-classify" | "LLM review";
  rule: string;
}

interface Props {
  tiers?: Tier[];
}

const defaultTiers: Tier[] = [
  {
    label: "Tier 1",
    range: "Hb < cohort threshold (e.g. < 7 g/dL ICU · < 8 g/dL non-ICU)",
    ruleOutput: "APPROPRIATE",
    routes: "auto-classify",
    rule: "Below cohort threshold. Auto-classified appropriate unless a higher-precedence bypass already fired (MTP cohort, peri-procedural ≤ 6h, delta-Hb trigger, hemodilution, or single-low-Hb-no-trend).",
  },
  {
    label: "Tier 2",
    range: "cohort threshold ≤ Hb < 10 g/dL",
    ruleOutput: "NEEDS_REVIEW",
    routes: "LLM review",
    rule: "Gray zone. Deterministic rule outputs NEEDS_REVIEW. The pipeline routes the row to the LLM for clinical reasoning.",
  },
  {
    label: "Tier 3",
    range: "Hb ≥ 10 g/dL",
    ruleOutput: "POTENTIALLY_INAPPROPRIATE",
    routes: "LLM review",
    rule: "High pre-transfusion Hb. Deterministic rule outputs POTENTIALLY_INAPPROPRIATE. The pipeline routes the row to the LLM, which may override on documented positive evidence.",
  },
];

const { tiers = defaultTiers } = Astro.props;

const pillClass = (c: Tier["ruleOutput"]) =>
  c === "APPROPRIATE" ? "ba-pill ba-pill--ok"
  : c === "POTENTIALLY_INAPPROPRIATE" ? "ba-pill ba-pill--err"
  : "ba-pill ba-pill--warn";

const routesPill = (r: Tier["routes"]) =>
  r === "auto-classify" ? "ba-pill ba-pill--ok" : "ba-pill ba-pill--warn";
---

<section class="hb-matrix" aria-label="3-tier Hb classification policy">
  <table class="hb-matrix__table">
    <thead>
      <tr>
        <th scope="col">Tier</th>
        <th scope="col">Hb range</th>
        <th scope="col">Rule output</th>
        <th scope="col">Routing</th>
        <th scope="col">Rule</th>
      </tr>
    </thead>
    <tbody>
      {tiers.map((t) => (
        <tr>
          <th scope="row">{t.label}</th>
          <td>{t.range}</td>
          <td><span class={pillClass(t.ruleOutput)}>{t.ruleOutput}</span></td>
          <td><span class={routesPill(t.routes)}>{t.routes}</span></td>
          <td>{t.rule}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="hb-matrix__note">
    Vitals (BP, HR, urine output, temperature) are <strong>supporting evidence only</strong>.
    They never override the Hb-based tier on their own. The acute-blood-loss override is
    the only path that bypasses the Hb threshold, and only with documented delta-Hb.
  </p>
</section>

<style>
  .hb-matrix { margin: 1rem 0; }
  .hb-matrix__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .hb-matrix__table th,
  .hb-matrix__table td {
    border: 1px solid var(--sl-color-gray-5);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .hb-matrix__table thead th {
    background: var(--sl-color-gray-6);
  }
  .hb-matrix__note {
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }
</style>
