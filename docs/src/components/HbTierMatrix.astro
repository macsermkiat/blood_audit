---
interface Tier {
  label: string;
  range: string;
  ruleOutput: "APPROPRIATE" | "NEEDS_REVIEW" | "POTENTIALLY_INAPPROPRIATE";
  routes: "auto-classify" | "LLM review";
  rule: string;
}

interface Props {
  tiers?: Tier[];
}

const isThai = Astro.url.pathname.includes("/th/");

const englishTiers: Tier[] = [
  {
    label: "Tier 1",
    range: "Hb < cohort threshold (7.0 default · 7.5 cardiac surgery · 8.0 selected cohorts)",
    ruleOutput: "APPROPRIATE",
    routes: "auto-classify",
    rule: "Below cohort threshold. Auto-classified appropriate unless hemodilution or single-low-Hb-no-trend sends the row to review. Higher-precedence bypasses may already have stopped the classifier.",
  },
  {
    label: "Tier 2",
    range: "cohort threshold ≤ Hb < 10 g/dL",
    ruleOutput: "NEEDS_REVIEW",
    routes: "LLM review",
    rule: "Gray zone. Deterministic rule outputs NEEDS_REVIEW. The pipeline routes the row to the LLM for clinical reasoning.",
  },
  {
    label: "Tier 3",
    range: "Hb ≥ 10 g/dL",
    ruleOutput: "POTENTIALLY_INAPPROPRIATE",
    routes: "LLM review",
    rule: "High pre-transfusion Hb. Deterministic rule outputs POTENTIALLY_INAPPROPRIATE. The pipeline routes the row to the LLM, which may override on documented positive evidence.",
  },
];

const thaiTiers: Tier[] = [
  {
    label: "Tier 1",
    range: "Hb < threshold ของ cohort (default 7.0 · cardiac surgery 7.5 · selected cohorts 8.0)",
    ruleOutput: "APPROPRIATE",
    routes: "auto-classify",
    rule: "Hb ต่ำกว่า threshold ของบริบททางคลินิก จึง auto-classify เป็น appropriate ได้ ยกเว้นมี hemodilution หรือ single-low-Hb-no-trend ที่ต้องส่ง review ก่อน",
  },
  {
    label: "Tier 2",
    range: "threshold ของ cohort ≤ Hb < 10 g/dL",
    ruleOutput: "NEEDS_REVIEW",
    routes: "LLM review",
    rule: "Gray zone deterministic rule ให้ NEEDS_REVIEW และ pipeline ส่งต่อให้ LLM ช่วยอ่านหลักฐานทางคลินิก",
  },
  {
    label: "Tier 3",
    range: "Hb ≥ 10 g/dL",
    ruleOutput: "POTENTIALLY_INAPPROPRIATE",
    routes: "LLM review",
    rule: "Hb ก่อนให้เลือดสูง จึง flag เป็น POTENTIALLY_INAPPROPRIATE แล้วส่ง LLM เพื่อค้นหาหลักฐานบวกที่บันทึกไว้ก่อนสรุปผล",
  },
];

const defaultTiers = isThai ? thaiTiers : englishTiers;
const { tiers = defaultTiers } = Astro.props;

const pillClass = (c: Tier["ruleOutput"]) =>
  c === "APPROPRIATE" ? "ba-pill ba-pill--ok"
  : c === "POTENTIALLY_INAPPROPRIATE" ? "ba-pill ba-pill--err"
  : "ba-pill ba-pill--warn";

const routesPill = (r: Tier["routes"]) =>
  r === "auto-classify" ? "ba-pill ba-pill--ok" : "ba-pill ba-pill--warn";

const routeText = (r: Tier["routes"]) => {
  if (!isThai) return r;
  return r === "auto-classify" ? "จำแนกอัตโนมัติ" : "ส่ง LLM review";
};

const tierNumber = (label: string) => label.replace(/[^0-9]/g, "") || "—";
---

<section class="hb-matrix" aria-label={isThai ? "นโยบาย classification แบบ 3-tier Hb" : "3-tier Hb classification policy"}>
  <div class="hb-matrix__table-wrap">
    <table class="hb-matrix__table">
      <thead>
        <tr>
          <th scope="col" class="hb-matrix__th-tier">Tier</th>
          <th scope="col">{isThai ? "ช่วง Hb" : "Hb range"}</th>
          <th scope="col">{isThai ? "ผลจาก rule" : "Rule output"}</th>
          <th scope="col">{isThai ? "เส้นทาง" : "Routing"}</th>
          <th scope="col">{isThai ? "คำอธิบาย rule" : "Rule"}</th>
        </tr>
      </thead>
      <tbody>
        {tiers.map((t) => (
          <tr>
            <th scope="row" class="hb-matrix__tier-cell">
              <span class="hb-matrix__tier-number" aria-hidden="true">
                {tierNumber(t.label)}
              </span>
              <span class="hb-matrix__tier-label">{t.label}</span>
            </th>
            <td class="hb-matrix__range">{t.range}</td>
            <td><span class={pillClass(t.ruleOutput)}>{t.ruleOutput}</span></td>
            <td><span class={routesPill(t.routes)}>{routeText(t.routes)}</span></td>
            <td class="hb-matrix__rule">{t.rule}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="hb-matrix__note">
    {isThai ? (
      <>
        Vitals (BP, HR, urine output, temperature) เป็น <strong>หลักฐานประกอบเท่านั้น</strong>
        และไม่ override Hb tier ด้วยตัวเอง deterministic bypass ต้องมีหลักฐานเชิงโครงสร้าง เช่น
        MTP, procedure timing, pre-op crossmatch หรือ delta-Hb
      </>
    ) : (
      <>
        Vitals (BP, HR, urine output, temperature) are <strong>supporting evidence only</strong>.
        They never override the Hb-based tier on their own. Deterministic bypasses require
        structured MTP, procedure-timing, pre-op crossmatch, or delta-Hb evidence.
      </>
    )}
  </p>
</section>

<style>
  .hb-matrix {
    margin: 1.25rem 0;
  }
  .hb-matrix__table-wrap {
    overflow-x: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.625rem;
    background: var(--sl-color-bg-nav);
  }
  .hb-matrix__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    margin: 0;
  }
  .hb-matrix__table th,
  .hb-matrix__table td {
    padding: 0.625rem 0.75rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.5;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }
  .hb-matrix__table tbody tr:last-child th,
  .hb-matrix__table tbody tr:last-child td {
    border-bottom: 0;
  }
  .hb-matrix__table tbody tr:nth-child(even) {
    background: color-mix(in oklch, var(--sl-color-gray-6) 50%, transparent);
  }
  .hb-matrix__table thead th {
    background: var(--sl-color-gray-6);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
  }
  .hb-matrix__th-tier {
    width: 6.5rem;
  }
  .hb-matrix__tier-cell {
    font-weight: 600;
    color: var(--sl-color-white);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .hb-matrix__tier-number {
    font-family: var(--ba-font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    line-height: 1;
  }
  .hb-matrix__tier-label {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .hb-matrix__range {
    color: var(--sl-color-gray-2);
    font-feature-settings: "tnum" 1;
  }
  .hb-matrix__rule {
    color: var(--sl-color-gray-2);
    max-width: 36rem;
  }
  .hb-matrix__note {
    margin: 0.875rem 0 0;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.55;
  }
</style>
