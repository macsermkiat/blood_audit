---
interface EnvVar {
  name: string;
  example: string;
  purpose: string;
  phase: "1" | "1.5";
}

interface Props {
  vars?: EnvVar[];
}

const defaultVars: EnvVar[] = [
  {
    name: "BBA_DATA_DIR",
    example: "/var/lib/blood_audit/data",
    purpose:
      "Persistent root for DuckDB + Parquet snapshots and the file-backed run-state store. Read by every CLI invocation.",
    phase: "1",
  },
  {
    name: "BBA_DB_URL",
    example: "postgresql+psycopg://bba@localhost/blood_audit",
    purpose:
      "Postgres DSN for batch_runs and review_actions. Read by the Phase 1.5 LLM analysis leg, not by Phase 1 ingest. Use the +psycopg driver suffix.",
    phase: "1.5",
  },
  {
    name: "ANTHROPIC_API_KEY",
    example: "sk-ant-…",
    purpose:
      "Batch API key for the LLM analysis leg. Read by Phase 1.5 wiring, not by Phase 1 ingest.",
    phase: "1.5",
  },
];

const { vars = defaultVars } = Astro.props;

const phaseLabel = (phase: EnvVar["phase"]) =>
  phase === "1" ? "required (Phase 1)" : "Phase 1.5";

const phasePill = (phase: EnvVar["phase"]) =>
  phase === "1" ? "ba-pill ba-pill--err" : "ba-pill ba-pill--warn";
---

<section class="env-checklist" aria-label="blood_audit environment variables">
  <ul class="ba-stack" role="list">
    {vars.map((v) => (
      <li class="ba-card env-row">
        <div class="ba-row env-row__head">
          <code class="env-name">{v.name}</code>
          <span class={phasePill(v.phase)}>{phaseLabel(v.phase)}</span>
        </div>
        <p class="env-purpose">{v.purpose}</p>
        <code class="env-example">{v.example}</code>
      </li>
    ))}
  </ul>
</section>

<style>
  .env-checklist { margin: 1rem 0; }
  .env-row__head { margin-bottom: 0.5rem; }
  .env-name { font-size: 1rem; font-weight: 600; }
  .env-purpose { margin: 0.25rem 0; }
  .env-example {
    display: block;
    margin-top: 0.5rem;
    padding: 0.25rem 0.5rem;
    background: var(--sl-color-gray-6);
    border-radius: 0.25rem;
    font-size: 0.85rem;
    word-break: break-all;
  }
</style>
