---
interface Step {
  index: string;
  question: string;
  evidence: string;
  yes: string;
  route: "Final" | "LLM";
  tone: "ok" | "warn" | "err";
  otherwise: string;
}

const isThai = Astro.url.pathname.includes("/th/");

const englishSteps: Step[] = [
  {
    index: "1",
    question: "No current pre-transfusion Hb?",
    evidence: "Lab: Hb observations, 7-day lookback",
    yes: "INSUFFICIENT_EVIDENCE",
    route: "Final",
    tone: "warn",
    otherwise: "Check global low-Hb rule",
  },
  {
    index: "2",
    question: "Hb < 7.0 g/dL?",
    evidence: "Lab: current Hb",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "Use cohort and bypass evidence",
  },
  {
    index: "3",
    question: "Cohort unknown?",
    evidence: "Procedure join availability",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "Check MTP pattern",
  },
  {
    index: "4",
    question: "Massive-transfusion-protocol cohort?",
    evidence: "Blood orders: RBC units, FFP, platelets in 1 h",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "Check procedural bypasses",
  },
  {
    index: "5",
    question: "Procedure <= 6 h before order?",
    evidence: "IPTSUMOPRT + ICD9CM procedure timing",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "Check pre-op crossmatch",
  },
  {
    index: "6",
    question: "Procedure <= 72 h after order?",
    evidence: "IPTSUMOPRT + ICD9CM upcoming procedure",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "Check acute Hb drop",
  },
  {
    index: "7",
    question: "Delta-Hb trigger fired?",
    evidence: "Lab: prior Hb drop in 6 / 12 / 24 h",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "Apply cohort threshold",
  },
  {
    index: "8",
    question: "No numeric threshold for cohort?",
    evidence: "ICD-10 + MED + ANC for active heme context",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "Compare Hb to threshold",
  },
  {
    index: "9",
    question: "Hb < cohort threshold?",
    evidence: "Lab Hb + cohort threshold + MED crystalloid check",
    yes: "APPROPRIATE unless safety flag",
    route: "Final",
    tone: "ok",
    otherwise: "Check gray zone",
  },
  {
    index: "10",
    question: "Threshold <= Hb < 10?",
    evidence: "Lab Hb + cohort threshold",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "High-Hb tier",
  },
  {
    index: "11",
    question: "Hb >= 10?",
    evidence: "Lab Hb",
    yes: "POTENTIALLY_INAPPROPRIATE",
    route: "LLM",
    tone: "err",
    otherwise: "Not reachable for valid Hb",
  },
];

const thaiSteps: Step[] = [
  {
    index: "1",
    question: "ไม่มี Hb ก่อนให้เลือดที่ใช้ได้?",
    evidence: "Lab: Hb observations, lookback 7 วัน",
    yes: "INSUFFICIENT_EVIDENCE",
    route: "Final",
    tone: "warn",
    otherwise: "ตรวจ Hb < 7.0 ก่อน",
  },
  {
    index: "2",
    question: "Hb < 7.0 g/dL?",
    evidence: "Lab: current Hb",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "ใช้ cohort และ bypass evidence ต่อ",
  },
  {
    index: "3",
    question: "Cohort unknown?",
    evidence: "availability ของ procedure join",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "ตรวจ MTP pattern",
  },
  {
    index: "4",
    question: "เข้า pattern MTP?",
    evidence: "Blood orders: RBC units, FFP, platelets ใน 1 ชั่วโมง",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "ตรวจ procedural bypass",
  },
  {
    index: "5",
    question: "มี procedure ≤ 6h ก่อน order?",
    evidence: "IPTSUMOPRT + ICD9CM procedure timing",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "ตรวจ pre-op crossmatch",
  },
  {
    index: "6",
    question: "มี procedure ≤ 72h หลัง order?",
    evidence: "IPTSUMOPRT + ICD9CM upcoming procedure",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "ตรวจ acute Hb drop",
  },
  {
    index: "7",
    question: "Delta-Hb trigger ทำงาน?",
    evidence: "Lab: prior Hb drop ใน 6 / 12 / 24h",
    yes: "APPROPRIATE",
    route: "Final",
    tone: "ok",
    otherwise: "ใช้ threshold ของ cohort",
  },
  {
    index: "8",
    question: "Cohort ไม่มี numeric threshold?",
    evidence: "ICD-10 + MED + ANC สำหรับ active heme context",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "เทียบ Hb กับ threshold",
  },
  {
    index: "9",
    question: "Hb < threshold ของ cohort?",
    evidence: "Lab Hb + cohort threshold + MED crystalloid check",
    yes: "APPROPRIATE ยกเว้น safety flag",
    route: "Final",
    tone: "ok",
    otherwise: "ตรวจ gray zone",
  },
  {
    index: "10",
    question: "threshold ≤ Hb < 10?",
    evidence: "Lab Hb + cohort threshold",
    yes: "NEEDS_REVIEW",
    route: "LLM",
    tone: "warn",
    otherwise: "เข้าสู่ high-Hb tier",
  },
  {
    index: "11",
    question: "Hb ≥ 10?",
    evidence: "Lab Hb",
    yes: "POTENTIALLY_INAPPROPRIATE",
    route: "LLM",
    tone: "err",
    otherwise: "ไม่ควรเกิดสำหรับ Hb ที่ valid",
  },
];

const steps = isThai ? thaiSteps : englishSteps;

const routeLabel = (route: Step["route"]) => {
  if (!isThai) return route;
  return route === "Final" ? "จบ ไม่เรียก LLM" : "ส่ง LLM";
};
---

<figure class="algorithm-flow" aria-labelledby="algorithm-flow-title">
  <figcaption id="algorithm-flow-title" class="algorithm-flow__caption">
    {isThai ? (
      <>
        ลำดับ precedence ของ deterministic classifier: rule แรกที่ match จะชนะ
        และมีเฉพาะ `NEEDS_REVIEW` กับ `POTENTIALLY_INAPPROPRIATE` ที่เข้าสู่เส้นทาง LLM
      </>
    ) : (
      <>
        Deterministic classifier precedence. The first matching row wins; only
        `NEEDS_REVIEW` and `POTENTIALLY_INAPPROPRIATE` continue to the LLM path.
      </>
    )}
  </figcaption>

  <div class="algorithm-flow__start">
    <span class="algorithm-flow__eyebrow">{isThai ? "ข้อมูลเข้า" : "Inputs"}</span>
    <strong>
      {isThai
        ? "คำสั่ง RBC + การหา Hb + cohort + เวลา procedure + crystalloid window"
        : "RBC order + Hb lookup + cohort + procedure timing + crystalloid window"}
    </strong>
  </div>

  <ol class="algorithm-flow__steps">
    {steps.map((step) => (
      <li class="algorithm-flow__step">
        <div class="algorithm-flow__node">
          <span class="algorithm-flow__index">{step.index}</span>
          <span class="algorithm-flow__node-copy">
            <span class="algorithm-flow__question">{step.question}</span>
            <span class="algorithm-flow__evidence">{step.evidence}</span>
          </span>
        </div>
        <div class="algorithm-flow__branches">
          <div class="algorithm-flow__branch algorithm-flow__branch--yes" data-tone={step.tone}>
            <span class="algorithm-flow__branch-label">{isThai ? "ใช่" : "Yes"}</span>
            <strong>{step.yes}</strong>
            <span class="algorithm-flow__route">{routeLabel(step.route)}</span>
          </div>
          <div class="algorithm-flow__branch algorithm-flow__branch--no">
            <span class="algorithm-flow__branch-label">{isThai ? "ไม่ใช่" : "No"}</span>
            <span>{step.otherwise}</span>
          </div>
        </div>
      </li>
    ))}
  </ol>

  <div class="algorithm-flow__footer">
    <span class="ba-pill ba-pill--ok">{isThai ? "จบโดยไม่เรียก LLM" : "Final without LLM"}</span>
    <span class="ba-pill ba-pill--warn">{isThai ? "เส้นทาง LLM review" : "LLM review route"}</span>
    <span class="ba-pill ba-pill--err">{isThai ? "Hb สูง น่ากังวล" : "High-Hb concern"}</span>
  </div>
</figure>

<style>
  .algorithm-flow {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
  }

  .algorithm-flow__caption {
    margin: 0 0 1rem;
    color: var(--sl-color-gray-2);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .algorithm-flow__start {
    display: grid;
    gap: 0.25rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--sl-color-accent);
    border-radius: 0.5rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-white);
  }

  .algorithm-flow__eyebrow,
  .algorithm-flow__branch-label,
  .algorithm-flow__route {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .algorithm-flow__eyebrow {
    color: var(--sl-color-accent-high);
  }

  .algorithm-flow__steps {
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .algorithm-flow__step {
    display: grid;
    grid-template-columns: minmax(12rem, 0.9fr) minmax(16rem, 1.4fr);
    gap: 0.75rem;
    align-items: stretch;
    position: relative;
  }

  .algorithm-flow__step + .algorithm-flow__step::before {
    content: "";
    position: absolute;
    top: -0.75rem;
    left: 1.25rem;
    width: 1px;
    height: 0.75rem;
    background: var(--sl-color-gray-5);
  }

  .algorithm-flow__node {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.625rem;
    align-items: center;
    min-height: 4.25rem;
    padding: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
  }

  .algorithm-flow__index {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent-high);
    font-family: var(--ba-font-mono);
    font-weight: 700;
  }

  .algorithm-flow__question {
    color: var(--sl-color-white);
    font-weight: 700;
    line-height: 1.35;
  }

  .algorithm-flow__node-copy {
    display: grid;
    gap: 0.25rem;
  }

  .algorithm-flow__evidence {
    color: var(--sl-color-gray-3);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .algorithm-flow__branches {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr);
    gap: 0.5rem;
  }

  .algorithm-flow__branch {
    display: grid;
    gap: 0.25rem;
    min-height: 4.25rem;
    padding: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-2);
  }

  .algorithm-flow__branch strong {
    color: var(--sl-color-white);
    font-size: 0.93rem;
    line-height: 1.35;
  }

  .algorithm-flow__branch--yes[data-tone="ok"] {
    border-color: oklch(70% 0.10 150);
    background: oklch(96% 0.025 150);
  }

  .algorithm-flow__branch--yes[data-tone="warn"] {
    border-color: oklch(72% 0.11 70);
    background: oklch(96% 0.035 70);
  }

  .algorithm-flow__branch--yes[data-tone="err"] {
    border-color: oklch(70% 0.13 28);
    background: oklch(96% 0.035 28);
  }

  :root[data-theme="dark"] .algorithm-flow__branch--yes[data-tone="ok"] {
    border-color: oklch(55% 0.12 150);
    background: oklch(24% 0.045 150);
  }

  :root[data-theme="dark"] .algorithm-flow__branch--yes[data-tone="warn"] {
    border-color: oklch(56% 0.12 70);
    background: oklch(25% 0.05 70);
  }

  :root[data-theme="dark"] .algorithm-flow__branch--yes[data-tone="err"] {
    border-color: oklch(56% 0.13 28);
    background: oklch(25% 0.055 28);
  }

  .algorithm-flow__route {
    color: var(--sl-color-gray-3);
  }

  .algorithm-flow__footer {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 50rem) {
    .algorithm-flow {
      padding: 0.75rem;
    }

    .algorithm-flow__step {
      grid-template-columns: 1fr;
    }

    .algorithm-flow__branches {
      grid-template-columns: 1fr;
    }

    .algorithm-flow__step + .algorithm-flow__step::before {
      left: 1rem;
    }
  }
</style>
